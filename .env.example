# ThreatHunter 環境變數範本
# 複製此檔案為 .env 並填入你的 Key
# 用法：cp .env.example .env

# LLM 供應商（openrouter / vllm / openai）
LLM_PROVIDER=openrouter

# OpenRouter API Key（開發用）
OPENROUTER_API_KEY=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

# NVD API Key（成員 B 申請）
NVD_API_KEY=

# OTX API Key（成員 B 申請）
OTX_API_KEY=

# GitHub Token（成員 C 申請）
GITHUB_TOKEN=

# vLLM 位址（比賽時才需要）
VLLM_BASE_URL=http://localhost:8000
