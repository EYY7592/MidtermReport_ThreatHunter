# ThreatHunter 環境變數模板
# 複製為 .env 並填入你的 API Key：cp .env.example .env

# ── LLM 供應商（三選一）──────────────────────────────────────
# 選項：openrouter / vllm / openai
LLM_PROVIDER=openrouter

# OpenRouter（開發用，Llama 3.3 70B）
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# vLLM（AMD Cloud 比賽用）
VLLM_BASE_URL=http://your-amd-cloud-url:8000/v1

# OpenAI（備案）
OPENAI_API_KEY=your_openai_api_key_here

# ── 外部 API Keys ────────────────────────────────────────────
# 成員 B 負責申請
NVD_API_KEY=your_nvd_api_key_here
OTX_API_KEY=your_otx_api_key_here

# 成員 C 負責申請
GITHUB_TOKEN=your_github_token_here

# ── Feature Flags ────────────────────────────────────────────
ENABLE_CRITIC=false
ENABLE_MEMORY_RAG=false

# ── Harness Engineering 參數 ─────────────────────────────────
MAX_DEBATE_ROUNDS=2
SIMILARITY_THRESHOLD=0.75
CONSTRAINT_THRESHOLD=0.75

# Sandbox Layer 2 (Docker Isolation)
SANDBOX_ENABLED=false   # true = �b Docker �e��?���� Pipeline
SANDBOX_IMAGE=threathunter-sandbox:latest
SANDBOX_TIMEOUT=300
SANDBOX_MEMORY=512m
SANDBOX_CPUS=1.0

# Phase 4C: WASM Runtime Sandbox (L0.5 Input Guard)
WASM_SANDBOX_ENABLED=true   # false = skip WASM layer, use Python-only L0 filter

# Phase 4D: Skill Hot-Reload Cache TTL
SKILL_CACHE_TTL=5.0   # seconds; 0 = always verify mtime (most real-time but slower)
