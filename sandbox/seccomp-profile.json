{
  "_comment": "ThreatHunter Sandbox seccomp profile — syscall whitelist for Python pipeline",
  "_design": "defaultAction=SCMP_ACT_ERRNO 阻擋所有未列的 syscall；只開放 Python 執行最小集合",
  "_windows_note": "seccomp 是 Linux 功能；Docker Desktop on Windows 透過 WSL2 kernel 支援此 profile",

  "defaultAction": "SCMP_ACT_ERRNO",
  "architectures": ["SCMP_ARCH_X86_64", "SCMP_ARCH_X86", "SCMP_ARCH_X32"],

  "syscalls": [
    {
      "_comment": "基本 I/O",
      "names": [
        "read", "write", "pread64", "pwrite64",
        "readv", "writev",
        "open", "openat", "openat2",
        "close", "dup", "dup2", "dup3",
        "lseek", "fseek"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "檔案系統（只讀操作）",
      "names": [
        "stat", "fstat", "lstat", "newfstatat",
        "statx", "statfs", "fstatfs",
        "access", "faccessat", "faccessat2",
        "readlink", "readlinkat",
        "getdents", "getdents64",
        "getcwd", "chdir", "fchdir"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "記憶體管理",
      "names": [
        "mmap", "mmap2", "munmap", "mprotect",
        "mremap", "madvise", "msync",
        "brk", "sbrk",
        "mlock", "munlock"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "進程控制（Python multiprocessing / threading 需要）",
      "names": [
        "clone", "clone3", "fork", "vfork",
        "execve", "execveat",
        "wait4", "waitpid", "waitid",
        "exit", "exit_group",
        "getpid", "getppid", "gettid",
        "getuid", "getgid", "geteuid", "getegid",
        "getgroups", "setgroups"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "訊號處理（Python signal module）",
      "names": [
        "rt_sigaction", "rt_sigprocmask", "rt_sigreturn",
        "rt_sigsuspend", "sigaltstack",
        "kill", "tgkill", "tkill"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "時間 / 計時（pipeline timeout 防護需要）",
      "names": [
        "nanosleep", "clock_nanosleep",
        "clock_gettime", "clock_getres",
        "gettimeofday", "settimeofday",
        "times", "time"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "同步原語（threading.Lock / threading.Event）",
      "names": [
        "futex", "futex_waitv",
        "set_robust_list", "get_robust_list",
        "set_tid_address"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Python ctypes / shared library 載入",
      "names": [
        "mmap", "munmap",
        "arch_prctl",
        "set_thread_area"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "polling（socket-less，Python select）",
      "names": [
        "select", "pselect6",
        "poll", "ppoll",
        "epoll_create", "epoll_create1",
        "epoll_ctl", "epoll_wait", "epoll_pwait"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "pipe（subprocess / threading.Event / Queue 需要）",
      "names": [
        "pipe", "pipe2"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "基本 IO control",
      "names": [
        "ioctl", "fcntl", "flock",
        "truncate", "ftruncate"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "tmpfs 寫入（/tmp 掛載為 noexec tmpfs）",
      "names": [
        "mkdir", "mkdirat",
        "unlink", "unlinkat",
        "rename", "renameat", "renameat2",
        "chmod", "fchmod", "fchmodat",
        "utimensat"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "系統資訊（Python platform 模組）",
      "names": [
        "uname", "sysinfo",
        "getrlimit", "setrlimit", "prlimit64",
        "prctl"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "網絡（注意：--network none 已阻擋所有對外連線，保留 socket 是為了 Unix domain socket）",
      "names": [
        "socket", "socketpair",
        "bind", "listen",
        "getsockopt", "setsockopt",
        "getsockname", "getpeername"
      ],
      "action": "SCMP_ACT_ALLOW",
      "_restriction": "AF_INET/AF_INET6 由 --network none 在 network namespace 層阻擋"
    }
  ]
}
