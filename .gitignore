# ──────────────────────────────────────────────────────────────────────────────
# ThreatHunter .gitignore
# master：只保留核心功能程式碼，排除 tests、data cache、logs、備份
# ──────────────────────────────────────────────────────────────────────────────

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
.python-version

# Secrets / Environment
.env
.env.*
!.env.example

# ── Runtime caches (API responses, NVD data) ──────────────────────────────────
data/
!data/.gitkeep

# ── Memory state (runtime JSON, not source code) ──────────────────────────────
memory/*.json
memory/*.bak
memory/*.backup*
memory/vector_store/*
!memory/.gitkeep
!memory/vector_store/.gitkeep

# ── Logs & Checkpoints (runtime artifacts) ────────────────────────────────────
logs/
*.log
log_*.txt

# ── Tests (不進 master) ───────────────────────────────────────────────────────
tests/
!tests/.gitkeep

# ── Temporary / patch scripts (工具腳本) ─────────────────────────────────────
_*.py
fix_*.py
patch_*.py
verify_*.py
check_*.py
api_test_*.py

# ── Documentation HTML (太大，保留 .md) ──────────────────────────────────────
docs/*.html

# ── Memory backup files ───────────────────────────────────────────────────────
*.backup_*
*.bak

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── pytest / ruff cache ───────────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Rust build artifacts ──────────────────────────────────────────────────────
rust/target/
*.whl
rust/prompt_sandbox/assets/*.wasm

# ── Docker artifacts ──────────────────────────────────────────────────────────
*.tar

# ── CI artifacts ──────────────────────────────────────────────────────────────
bandit_report.json
arch_linter_output.txt

# ── OSV / exploit data caches (runtime) ──────────────────────────────────────
data/osv_cache_*
data/exploit_cache_*
data/nvd_cache_*
data/otx_cache_*
data/epss_cache.json
data/ghsa_cache.json
data/kev_cache.json

# ── Tool specific ─────────────────────────────────────────────────────────────
.gemini/
.opencode/
tmp_*
advisor_memory.json
